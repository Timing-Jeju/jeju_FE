{
  "expo": {
    "name": "tourist",
    "slug": "tourist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tourist",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yonghyeog.tourist"
    },
    "android": {
      "package": "com.yonghyeog.tourist",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "@mj-studio/react-native-naver-map",
        {
          "client_id": "YOUR_NCP_MAPS_CLIENT_ID",
          "android": {
            "ACCESS_FINE_LOCATION": true,
            "ACCESS_COARSE_LOCATION": true
          },
          "ios": {
            "NSLocationWhenInUseUsageDescription": "현재 위치에서 목적지까지 경로를 안내하기 위해 위치 정보가 필요합니다."
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "현재 위치에서 목적지까지 경로를 안내하기 위해 위치 정보가 필요합니다."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": ["https://repository.map.naver.com/archive/maven"]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
